{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-spec.dev/schemas/agent-spec/intent-compiler/worktree-manifest-v1.schema.json",
  "title": "agent-spec requirements worktree manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "entries",
    "diagnostics"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entry"
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_unit_id",
        "requirement_id",
        "batch",
        "base_branch",
        "branch",
        "path",
        "spec_path",
        "depends_on"
      ],
      "properties": {
        "work_unit_id": {
          "type": "string",
          "pattern": "^WU-REQ-[A-Z0-9][A-Z0-9-]*$"
        },
        "requirement_id": {
          "type": "string",
          "pattern": "^REQ-[A-Z0-9][A-Z0-9-]*$"
        },
        "batch": {
          "type": "integer",
          "minimum": 0
        },
        "base_branch": {
          "type": "string",
          "minLength": 1
        },
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "spec_path": {
          "type": "string",
          "minLength": 1
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^REQ-[A-Z0-9][A-Z0-9-]*$"
          }
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "severity",
        "requirement_id",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "enum": [
            "info",
            "warning",
            "error"
          ]
        },
        "requirement_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
