{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-spec.dev/schemas/agent-spec/intent-compiler/clarification-questions-v1.schema.json",
  "title": "agent-spec requirements clarification questions v1",
  "type": "array",
  "items": {
    "$ref": "#/$defs/question"
  },
  "$defs": {
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "target_id",
        "diagnostic_code",
        "blocking",
        "prompt",
        "source",
        "options"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "target_id": {
          "type": "string",
          "minLength": 1
        },
        "diagnostic_code": {
          "type": "string",
          "minLength": 1
        },
        "blocking": {
          "type": "boolean"
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "options": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
